{
  "hosting": {
    "site": "gsc-seo",
    "source": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "/api/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-store, no-cache, must-revalidate, private, max-age=0"
          },
          {
            "key": "Pragma",
            "value": "no-cache"
          }
        ]
      }
    ],
    "frameworksBackend": {
      "region": "us-central1",
      "memory": "1GiB",
      "cpu": 1,
      "minInstances": 0,
      "maxInstances": 10,
      "concurrency": 80
    }
  },
  "firestore": {
    "database": "(default)",
    "location": "us-central1",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "auth": {
    "providers": {
      "emailPassword": true,
      "googleSignIn": {
        "oAuthBrandDisplayName": "Cele",
        "supportEmail": "hello@cele.app"
      }
    }
  }
}
